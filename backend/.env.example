# ===== App =====
APP_NAME=Workflow Discovery Agent
VERSION=0.1.0
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ===== Database (PostgreSQL) =====
# 端口避让：宿主机其他项目占用了 5432，本项目用 5433
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/wda

# ===== Redis =====
# 端口避让：宿主机其他项目占用了 6379，本项目用 6380
REDIS_URL=redis://localhost:6380/0

# ===== Celery =====
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ===== LLM (火山引擎方舟 Claude 兼容协议, 底层 GLM-5.2) =====
# 同时支持 LLM_ 和 VOLC_ 前缀
VOLC_API_KEY=your-volc-api-key-here
VOLC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
VOLC_MODEL=ark-code-latest

# 或者用 Anthropic 官方
# ANTHROPIC_API_KEY=your-anthropic-key
# ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5
# ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
# ANTHROPIC_MODEL_OPUS=claude-opus-4-7

# ===== Search =====
# SerpAPI key (可选，默认用 ddgs 库免费)
SERPAPI_KEY=
SERPAPI_DEFAULT_NUM=15

# ===== Agent =====
AGENT_MAX_ITERATIONS=20
AGENT_MAX_TOKENS_PER_CALL=4096
AGENT_SCORE_THRESHOLD=7.0

# ===== JWT =====
# 生产环境必须改！用 openssl rand -hex 32 生成
JWT_SECRET=change-this-to-random-32-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
